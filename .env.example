# Azaka Environment Variables

# Network (testnet, mainnet, futurenet)
NETWORK=testnet

# Contract IDs (update after deployment)
TRADE_CONTRACT_ID=C...
ESCROW_CONTRACT_ID=C...
DOCUMENT_CONTRACT_ID=C...
REGISTRY_CONTRACT_ID=C...

# Deployer
DEPLOYER_ADDRESS=G...

# Optional: RPC URL override
# RPC_URL=https://soroban-testnet.stellar.org

# Optional: Bank secret key (for bank integration)
# BANK_SECRET_KEY=S...

# Optional: USDC contract address
# USDC_ADDRESS=C...
